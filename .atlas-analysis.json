  "keyFeatures": [
    "Local-first architecture with offline support",
    "Real-time collaboration using CRDTs (Yjs)",
    "Rich text editor with Notion-like blocks",
    "Databases with multiple views (table, kanban, calendar)",
    "Built-in chat and messaging",
    "File storage and management",
    "Self-hostable with Docker and Kubernetes",
    "Cross-platform (Web and Electron desktop)",
    "Type-safe with TypeScript and Zod validation",
    "Monorepo architecture with Turbo"
