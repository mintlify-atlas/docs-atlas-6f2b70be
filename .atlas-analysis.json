    "openDatabase() - Initialize client database",
    "queryNodes() - Query workspace nodes",
    "createNode() - Create workspace nodes",
    "updateNode() - Update node attributes",
    "deleteNode() - Delete workspace nodes",
    "Node types: space, folder, page, database, database-view, record, field, channel, message, file",
